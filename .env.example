# --- Supabase (nube) -----------------------------------------
# Disponibles en: Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Disponible en: Project Settings → Database → Connection string → URI
# Reemplazar [YOUR-PASSWORD] con la database password del proyecto
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# --- APIs externas -------------------------------------------
# YouTube Data API v3: console.cloud.google.com
# Restringir la key al Extension ID en Google Cloud Console
YOUTUBE_API_KEY=

# Last.fm: last.fm/api/account/create
LASTFM_API_KEY=

# Identificador del agente para MusicBrainz
MUSICBRAINZ_USER_AGENT=

# --- Seguridad -----------------------------------------------
# Shared secret entre la extensión Chrome y la Edge Function ingest.
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
GMC_INGEST_SECRET=

# --- Edge Function -------------------------------------------
EDGE_FUNCTION_URL=